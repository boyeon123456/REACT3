rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email != null && (request.auth.token.email == 'boyeon5600@gmail.com' || request.auth.token.email == 'admin_test_123@school.com')) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // 차단 여부 확인 (문서가 없을 때는 차단되지 않은 것으로 간주)
    function isNotBanned() {
      return isAuthenticated() && 
        (!exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
         !('isBanned' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false);
    }

    // ──────────────────────────────────────────
    // 유저 문서
    // ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      // 가입 시 create는 isNotBanned 없이 허용
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId && isNotBanned();
      allow delete: if isAdmin();

      // 인벤토리 (서브컬렉션)
      match /inventory/{itemId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ──────────────────────────────────────────
    // 학교 통계 및 랭킹 (school_stats)
    // ──────────────────────────────────────────
    match /school_stats/{schoolCode} {
      allow read: if true;
      allow write: if isAuthenticated() && isNotBanned();
    }

    // ──────────────────────────────────────────
    // 게시글 및 댓글
    // ──────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBanned();
      allow update: if isNotBanned();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.author_id);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated() && isNotBanned();
        allow update: if isNotBanned();
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.author_id);
      }
    }

    // ──────────────────────────────────────────
    // 기타 컬렉션
    // ──────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
    }

    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated() && isNotBanned();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /timetables/{ttId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /shop_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
