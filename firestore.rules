rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────
    // Helpers
    // ──────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'boyeon5600@gmail.com' ||
         request.auth.token.email == 'admin_test_123@school.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }



    function isNotBanned() {
      return isAuthenticated() && 
        (!('isBanned' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == false);
    }

    // 유저 문서

    // 읽기: 로그인한 모든 유저 (리더보드, 프로필 표시용)
    // 쓰기: 본인 문서만 수정 가능
    // ──────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId && isNotBanned();
    }


    // ──────────────────────────────────────────
    // 게시글
    // 읽기: 비로그인도 허용 (공개 게시판)
    // 작성: 로그인 필수
    // 수정: 로그인 유저 (likes, views, comments 카운트 업데이트 포함)
    // 삭제: 작성자 본인 또는 관리자만
    // ──────────────────────────────────────────
    match /posts/{postId} {
      allow read: if true;
      allow create: if isNotBanned();
      allow update: if isNotBanned();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.author_id);

      // 댓글 서브컬렉션
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isNotBanned();
        allow update: if isNotBanned();
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.author_id);
      }
    }


    // ──────────────────────────────────────────
    // 알림 (notifications)
    // 읽기/쓰기: 알림 수신자 본인 또는 알림 생성 시 (로그인 필수)
    // ──────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // 신고 (reports)
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isNotBanned();
      allow update, delete: if isAdmin();
    }

    // 시스템 설정 (settings)
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 시간표 (timetables)
    match /timetables/{ttId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 상점 아이템 (shop_items)
    match /shop_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 유저별 인벤토리 (서브컬렉션)
    match /users/{userId}/inventory/{itemId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}



